# ==========================================
# Application
# ==========================================

APP_NAME=school_software_backend
APP_ENV=development
PORT=8080

# ==========================================
# Database (Neon PostgreSQL)
# ==========================================

DATABASE_URL=postgres://username:password@host/database?sslmode=require

# ==========================================
# Authentication
# ==========================================

JWT_SECRET=replace-with-a-long-random-secret

# ==========================================
# Logging
# ==========================================

LOG_LEVEL=debug

# ==========================================
# Cloudflare R2 Storage
# ==========================================

R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=